{
  "statusLine": {
    "type": "command",
    "command": "${CLAUDE_PLUGIN_ROOT}/scripts/statusline.sh",
    "refreshInterval": 5,
    "padding": 1
  },
  "env": {
    "THESPIN_URL": "https://thespin.ad",
    "THESPIN_SPINNER_VERBS": "1",
    "THESPIN_NOTIFY": "0"
  },
  "hooks": {
    "SessionStart": [
      {
        "hooks": [
          { "type": "command", "command": "${CLAUDE_PLUGIN_ROOT}/scripts/spinner-verbs.sh" }
        ]
      }
    ],
    "Notification": [
      {
        "hooks": [
          { "type": "command", "command": "${CLAUDE_PLUGIN_ROOT}/scripts/notice.sh" }
        ]
      }
    ]
  },
  "spinnerVerbs": {
    "mode": "replace",
    "verbs": ["Sponsored by your highest bid", "Monetizing the wait", "Discombobulating"]
  }
}
